<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.myapplication1.MediaActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/padding_screen_16"
        android:paddingTop="@dimen/padding_screen_32"
        android:paddingEnd="@dimen/padding_screen_16">

        <FrameLayout
            android:layout_width="@dimen/header_height"
            android:layout_height="@dimen/header_height">

            <ImageView
                android:id="@+id/back_button"
                android:layout_width="@dimen/margin_24"
                android:layout_height="@dimen/margin_24"
                android:layout_gravity="center"
                android:src="@drawable/ic_back" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_bottom_8"
            android:text="@string/search"
            android:textColor="@color/black"
            android:textSize="@dimen/text_body_22" />
    </LinearLayout>


</LinearLayout>